# Streamlit Cloud Secrets 配置示例
# 在 Streamlit Cloud 部署后，需要在 app settings → Secrets 中添加以下内容

[llm]
provider = "openai_compatible"
api_key = "your-api-key-here"
model = "gpt-4o-mini"
base_url = "https://api.openai.com/v1"
timeout = 30

[embedding]
model = "BAAI/bge-m3"
api_key = "your-embedding-api-key"
base_url = "https://your-embedding-service.com"

[audio]
api_key = "your-audio-api-key"
