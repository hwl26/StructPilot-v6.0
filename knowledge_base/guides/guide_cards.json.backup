              "image_id": "2",
              "path": "assets/guides/cp_05_extract/bin1 extract.png",
              "caption": "bin1 extract.png"
            }
          ],
          "caption": "根据挑出的颗粒坐标，从运动校正后的显微图中提取颗粒图像",
          "parameters": [
            {
              "id": "box_size",
              "name": "Extraction box size (pix)",
              "name_cn": "提取框大小",
              "name_en": "Extraction box size (pix)",
              "type": "number",
              "default": "particle的直径A/0.9/0.96(A/pix) *1.5-2",
              "meaning": "提取颗粒的框大小（像素）",
              "official_doc": "设为颗粒直径的 1.5-2.0 倍（以像素为单位）。太小会截断颗粒边缘，太大会包含过多背景。",
              "lab_experience": "公式：particle直径(Å) / pixel_size(Å/px) × 1.5~2.0；实验室常用 240 px（pixel=0.96 时）",
              "common_mistake": "框太小会截断颗粒边缘，影响后续 2D/3D 分类；框太大会增加计算量和内存占用"
            },
            {
              "id": "fourier_crop",
              "name": "Fourier crop to box size (pix)",
              "name_cn": "Fourier crop 框大小",
              "name_en": "Fourier crop to box size (pix)",
              "type": "number",
              "default": "100~120",
              "meaning": "Fourier crop 后的框大小（像素），用于加速计算",
              "official_doc": "设为 2 的幂（如 64, 128, 256）。Fourier crop 会降低分辨率但加快计算。",
              "lab_experience": "第一轮 Fourier crop=100~120 px（不超过 2^8=128 保证计算效率）；第二轮精细挑不用 bin，关闭 Fourier crop",
              "common_mistake": "超过 128 计算量大；Fourier crop 太小会丢失高频信号"
            },
            {
              "id": "invert_contrast",
              "name": "Invert contrast",
              "name_cn": "反转对比度",
              "name_en": "Invert contrast",
              "type": "boolean",
              "default": "True",
              "meaning": "是否反转颗粒图像的对比度（黑白反转）",
              "official_doc": "默认开启。冷冻电镜数据中，蛋白颗粒比背景亮（正对比度），但有些软件期望负对比度。",
              "lab_experience": "保持开启",
              "common_mistake": "对比度不正确会导致后续 2D/3D 分类结果异常"
            },
            {
              "id": "normalize",
              "name": "Normalize particles",
              "name_cn": "归一化",
              "name_en": "Normalize particles",
              "type": "boolean",
              "default": "True",
              "meaning": "是否对颗粒图像进行归一化（均值为 0，标准差为 1）",
              "official_doc": "默认开启。归一化可以提高分类和重构的稳定性。",
              "lab_experience": "保持开启",
              "common_mistake": "关闭归一化会导致分类和重构结果不稳定"
            }
          ]
        }
      ]
