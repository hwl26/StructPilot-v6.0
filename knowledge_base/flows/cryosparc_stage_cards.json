    "name": "motion_correction",
    "label_cn": "运动校正",
    "goal": "对原始 movies 进行帧对齐，校正样品漂移和束诱导运动，输出高质量平均显微图。",
    "inputs": [
      "原始 movies",
      "增益参考文件",
      "采集参数（dose per frame 等）"
    ],
    "cryosparc_jobs": [
