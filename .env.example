# StructPilot v5.2 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件已在 .gitignore 中，不会被提交到版本控制

# ============= LLM 配置 =============
# 服务商：openai_compatible / anthropic / gemini / none
STRUCTPILOT_LLM_PROVIDER=openai_compatible

# API Key（必填，启用 LLM 时需要）
STRUCTPILOT_LLM_API_KEY=your_api_key_here

# 模型名称
STRUCTPILOT_LLM_MODEL=Qwen/Qwen3-VL-32B-Instruct

# API Base URL
STRUCTPILOT_LLM_BASE_URL=https://api.siliconflow.cn/v1

# 请求超时（秒）
STRUCTPILOT_LLM_TIMEOUT=30

# ============= Embedding 配置（用于 RAG 检索）===========
# Embedding 模型名称
STRUCTPILOT_EMBEDDING_MODEL=BAAI/bge-m3

# Embedding API Base URL（留空则复用主 LLM 的 base_url）
STRUCTPILOT_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# Embedding API Key（留空则复用主 LLM 的 api_key）
STRUCTPILOT_EMBEDDING_API_KEY=your_embedding_api_key_here

# ============= 语音转写配置（用于语音输入）===========
# OpenAI-compatible /audio/transcriptions 模型名称
# 硅基流动接口模型：FunAudioLLM/SenseVoiceSmall
STRUCTPILOT_AUDIO_MODEL=FunAudioLLM/SenseVoiceSmall

# Audio API Base URL（留空则复用主 LLM 的 base_url）
STRUCTPILOT_AUDIO_BASE_URL=https://api.siliconflow.cn/v1

# Audio API Key（留空则复用主 LLM 的 api_key）
STRUCTPILOT_AUDIO_API_KEY=your_audio_api_key_here

# ============= 截图目录配置 =============
# 各步骤截图（上级目录 StructPilot_Visual_UI/StructPilot_Visual_UI/images）的根目录。
# 默认自动指向项目同级的 StructPilot_Visual_UI/StructPilot_Visual_UI/images；
# 如需自定义，请填绝对路径。
# STRUCTPILOT_SCREENSHOTS_DIR=D:/xwechat_files/.../2026-07/StructPilot_Visual_UI/StructPilot_Visual_UI/images

# ============= 运行态目录（可选）============
# 会话记忆 / 上传 / OCR 缓存目录。为兼容既有用户，默认目录名仍保留 StructPilot_v4_runtime。
# STRUCTPILOT_RUNTIME_DIR=D:/path/to/StructPilot_v4_runtime
